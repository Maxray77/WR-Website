# Wildlife Rescue Website — Local environment variables
# Copy this file to .env.local and fill in real values.

# ── Wingman AI chatbot (OpenAI) ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Google Analytics 4 (optional) ────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Razorpay donate button (optional override; falls back to hardcoded ID) ──
NEXT_PUBLIC_RAZORPAY_BUTTON_ID=pl_H4Jwn7xLqMgktI

# ── Upstash Redis (rate limiting + persistent storage) ──────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Sanity (blog CMS) ────────────────────────────────────────────────────────
# Get these from https://sanity.io/manage after creating a project.
# The site keeps using the static blog data until both PROJECT_ID and DATASET
# are set, so it's safe to leave blank during initial setup.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Used by the migration script and for ISR revalidation.
# Create at https://sanity.io/manage → API → Tokens (Editor permission).
SANITY_API_WRITE_TOKEN=

# Random secret string. Used to authenticate Sanity → Vercel webhook calls
# that invalidate the blog cache when content changes. Generate with:
#   openssl rand -hex 32
SANITY_REVALIDATE_SECRET=
